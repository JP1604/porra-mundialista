# ── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ── football-data.org (GRATIS, cubre WC 2026) ────────────────────
# Regístrate en: https://www.football-data.org/client/register
# Te mandan el token por email al instante
FOOTBALL_DATA_TOKEN=tu-token-aqui

# ── Sync ─────────────────────────────────────────────────────────
# Cada cuántos minutos se sincronizan resultados (recomendado: 30)
SYNC_INTERVAL_MINUTES=30
